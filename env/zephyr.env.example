# Zephyr Scale Cloud credentials for publishing test cycles/executions.
# Copy this file to env/zephyr.env and fill in real values.
# env/zephyr.env is gitignored (env/*) — never commit real tokens.

# Required
ZEPHYR_API_TOKEN=<your zephyr scale api token>
ZEPHYR_BASE_URL=https://api.zephyrscale.smartbear.com/v2
ZEPHYR_PROJECT_KEY=PRE

# Executions are assigned to this Jira/Zephyr accountId.
ZEPHYR_ASSIGNEE_ACCOUNT_ID=<your jira/zephyr accountId>

# Optional — for printing clickable cycle links (instance-specific).
ZEPHYR_APP_URL=https://<site>.atlassian.net/jira/software/projects/PRE/apps/<appId>/<moduleId>
ZEPHYR_JIRA_PROJECT_ID=<numeric jira project id>

# Optional — test cycle folder placement.
# Default (unset): auto-pick the latest release-version folder (e.g. 2026.7.1).
#   ZEPHYR_FOLDER_NAME=2026.7.1
#   ZEPHYR_FOLDER_ID=43758905
