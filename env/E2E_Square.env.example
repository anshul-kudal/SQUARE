# Copy to env/E2E_Square.env and fill in your IO / Square / NetSuite credentials.
# Required for all runs: NODE_ENV=dev SETUP=E2E_Square PBI=SQNS SUITE=Square_Suite

FILE_NAME=E2E_Square
ENVIRONMENT=IAQA
RP_REPORT_OPTION=local
RP_LAUNCH=IA_API_SQUARE
RP_PROJECT=IA_SQUARE_SUITES
PBI=SQNS

BASE_URL=https://iaqa.staging.integrator.io
API_V1=https://api.iaqa.staging.integrator.io/v1
Integrator.baseurl=https://api.iaqa.staging.integrator.io/
Integrator.userName=<base64-email>
Integrator.password=<base64-password>
Integrator.token=<base64-bearer-token>

CONNECTIONS.IO_CONNECTOR_IDENTIFIER=Square - NetSuite
CONNECTIONS.SQUARE=<square-connection-id>
CONNECTIONS.SQUARE_TOKEN=<base64-square-access-token>
CONNECTIONS.NETSUITE=<netsuite-connection-id>
CONNECTIONS.NS_ACCOUNT_IDENTIFIER=<ns-account-id>
CONNECTIONS.SQUARE_INTEGRATION_ID=<integration-id>
CONNECTIONS.SQUARE_NS_INTEGRATION=<integration-id>
CONNECTIONS.SQUARE_CHILD_ACCOUNT_ID=<square-location-account-id>

# Framework store slot (legacy name — required by @celigo/rest-api-ia-automation)
SHOPIFY_PRIMARY_STORE_DATA.STORE_NAME=<square-store-name>
SHOPIFY_PRIMARY_STORE_DATA.STORE_ID=<square-store-id>
CONNECTIONS.SHOPIFY_STORE_1=<same-as-CONNECTIONS.SQUARE>

SQUARE_PRIMARY_STORE_DATA.STORE_ID=<square-store-id>
SQUARE_PRIMARY_STORE_DATA.STORE_NAME=<square-store-name>
SQUARE_PRIMARY_STORE_DATA.LOCATION_ID=<square-location-id>

SQUARE_CATALOG.BOTTLE_ITEM_ID=<catalog-item-id>
SQUARE_CATALOG.BOTTLE_VARIATION_ID=<variation-id>
SQUARE_CATALOG.TEST_PRODUCT_ID=<product-id>
SQUARE_CATALOG.TAX_NY_8_ID=<tax-id>
SQUARE_CATALOG.MODIFIER_ID=<modifier-id>
SQUARE_CATALOG.MODIFIER_LIST_ID=<modifier-list-id>

SQUARE_FLOWS.ORDER_CASHSALE_ID=<order-import-flow-id>
SQUARE_FLOWS.REFUND_CASHREFUND_ID=<refund-flow-id>

DEFAULT_CUSTOMER.EMAIL=<default-customer-email>
DEFAULT_CUSTOMER.ID=<netsuite-customer-internal-id>
DEFAULT_CUSTOMER.FIRST_NAME=<first-name>
DEFAULT_CUSTOMER.LAST_NAME=<last-name>

DEFAULTS.PRODUCTS.0.SKU=Celigo Steel Water Bottle
DEFAULTS.PRODUCTS.0.PRICE=19.40
DEFAULTS.PRODUCTS.1.SKU=Test product
DEFAULTS.PRODUCTS.1.PRICE=19.40
DEFAULT_DISCOUNT.DISCOUNTS.0.NAME=DIS00000

AUT.SH=Square
AUT.NS=Netsuite
CURRENCY.SQUARE=USD
CURRENCY.NETSUITE=USD
ENV=IAQA.STAGING

NS_LOCATION_ID.ID=6
NS_TAX_PREFERENCE_DETAILS.DEPLOY_ID=customdeploy1
NS_TAX_PREFERENCE_DETAILS.SCRIPT_ID=customscript700
NS_SETTLE_DELAY_MS=10000
NS_EMPTY_RESULT_RETRIES=5
NS_EMPTY_RESULT_DELAY_MS=15000
TEST_MAX_RETRIES=3

RESET_FLOW_STATUS_PATH=/config/resetFlowStatus_Square.json
RESET_SETTINGS_PATH=/config/resetSettings_Square.json
SQUARE_NS.NOSKU_TRACK_ITEM_ID=<nosku-track-item-id>
REFRESH_MAP=[]

SQUARE_ORDER.SC1.PRICE_CENTS=1940
SQUARE_ORDER.SC1.DISCOUNT_PERCENT=25.0
